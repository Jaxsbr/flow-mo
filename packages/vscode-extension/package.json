{
  "name": "flow-mo-vscode",
  "displayName": "FlowMo",
  "description": "Visual YAML flow diagram editor for *.flow.yaml files",
  "version": "0.1.0",
  "publisher": "jaxsbr",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jaxsbr/flow-mo.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "flowMo.flowYaml",
        "displayName": "FlowMo Diagram",
        "selector": [
          {
            "filenamePattern": "*.flow.yaml"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "~5.9.3"
  }
}
