{
  "name": "flow-mo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:webview": "vite build --config vite.webview.config.ts",
    "package:ext": "npm run build:webview && npm run compile --workspace=packages/vscode-extension && npm run package --workspace=packages/vscode-extension",
    "deploy:cursor": "npm run build --workspace=packages/core && npm run build && npm run package:ext && cursor --install-extension packages/vscode-extension/flow-mo-vscode-0.1.0.vsix --force",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm test --workspaces --if-present"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
